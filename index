<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>INFRA - Material de apoyo SAP</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
  :root {
    --orange: #F47920;
    --orange-light: #FEF0E6;
    --orange-dark: #D4640F;
    --blue: #1B3A6B;
    --blue-dark: #142d54;
    --bg: #F5F5F5;
    --bg-card: #FFFFFF;
    --border: rgba(0,0,0,0.10);
    --text-primary: #1a1a1a;
    --text-secondary: #555;
    --text-muted: #999;
    --radius-md: 8px;
    --radius-lg: 12px;
    --font: 'IBM Plex Sans', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; font-family: var(--font); background: var(--bg); color: var(--text-primary); }

  .portal { display: flex; height: 100vh; overflow: hidden; }

  /* ── SIDEBAR ── */
  .sidebar {
    width: 290px; min-width: 290px;
    background: var(--blue);
    display: flex; flex-direction: column; overflow: hidden;
  }
  .sidebar-header {
    padding: 20px 18px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.10);
    background: var(--blue-dark);
    flex-shrink: 0;
  }
  .sidebar-logo-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
  .sidebar-logo-img { height: 30px; object-fit: contain; }
  .sidebar-subtitle { font-size: 10px; font-weight: 500; color: rgba(255,255,255,0.45); letter-spacing: .08em; text-transform: uppercase; }
  .sidebar-title { font-size: 13px; font-weight: 600; color: #fff; margin-top: 2px; }

  .sidebar-list { overflow-y: auto; flex: 1; padding: 6px 0 12px; }
  .sidebar-list::-webkit-scrollbar { width: 4px; }
  .sidebar-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 4px; }

  /* módulo acordeón */
  .module-block { border-bottom: 1px solid rgba(255,255,255,0.06); }

  .module-header {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 18px; cursor: pointer;
    border-left: 3px solid transparent;
    transition: background .12s;
    user-select: none;
  }
  .module-header:hover { background: rgba(255,255,255,0.07); }
  .module-header.active { background: rgba(244,121,32,0.15); border-left-color: var(--orange); }

  .mod-num { font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.35); min-width: 20px; flex-shrink: 0; }
  .module-header.active .mod-num { color: var(--orange); }
  .mod-label { font-size: 12px; color: rgba(255,255,255,0.72); line-height: 1.35; flex: 1; }
  .module-header.active .mod-label { color: #fff; font-weight: 500; }
  .mod-badge { font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 20px; background: var(--orange); color: #fff; flex-shrink: 0; }
  .mod-arrow { font-size: 10px; color: rgba(255,255,255,0.35); transition: transform .2s; flex-shrink: 0; }
  .module-header.active .mod-arrow { transform: rotate(90deg); color: var(--orange); }

  /* sub-lista */
  .module-videos { max-height: 0; overflow: hidden; transition: max-height .28s ease; background: rgba(0,0,0,0.18); }
  .module-videos.open { max-height: 600px; }

  .sidebar-video-item {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 18px 8px 36px; cursor: pointer;
    border-left: 3px solid transparent;
    transition: background .1s;
  }
  .sidebar-video-item:hover { background: rgba(255,255,255,0.06); }
  .sidebar-video-item.active-video { background: rgba(244,121,32,0.12); border-left-color: var(--orange); }

  .sv-dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.25); flex-shrink: 0; transition: background .1s; }
  .sidebar-video-item.active-video .sv-dot,
  .sidebar-video-item:hover .sv-dot { background: var(--orange); }

  .sv-label { font-size: 11px; color: rgba(255,255,255,0.6); line-height: 1.35; flex: 1; }
  .sidebar-video-item.active-video .sv-label { color: #fff; }

  .sidebar-empty { padding: 10px 18px 10px 36px; font-size: 11px; color: rgba(255,255,255,0.3); font-style: italic; }

  /* ── MAIN ── */
  .main { flex: 1; overflow-y: auto; display: flex; flex-direction: column; min-width: 0; }

  .main-topbar {
    background: var(--orange); padding: 10px 32px;
    display: flex; align-items: center; gap: 6px; flex-shrink: 0;
  }
  .topbar-crumb { font-size: 12px; color: rgba(255,255,255,0.8); }
  .topbar-sep { font-size: 12px; color: rgba(255,255,255,0.5); }
  .topbar-current { font-size: 12px; color: #fff; font-weight: 500; }

  .main-header { background: var(--bg-card); border-bottom: .5px solid var(--border); padding: 20px 32px 18px; flex-shrink: 0; }
  .main-title { font-size: 22px; font-weight: 600; color: var(--blue); }
  .main-subtitle { font-size: 13px; color: var(--text-muted); margin-top: 4px; }

  .main-body { padding: 24px 32px; flex: 1; max-width: 860px; }

  /* objetivo */
  .objective-box {
    background: var(--bg-card); border: .5px solid var(--border);
    border-left: 4px solid var(--orange); border-radius: var(--radius-md);
    padding: 16px 18px; margin-bottom: 28px;
    display: flex; gap: 12px; align-items: flex-start;
  }
  .obj-icon { width: 32px; height: 32px; background: var(--orange-light); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .obj-label { font-size: 10px; font-weight: 600; color: var(--orange-dark); margin-bottom: 4px; text-transform: uppercase; letter-spacing: .06em; }
  .obj-text { font-size: 13px; color: var(--text-primary); line-height: 1.6; }

  /* hero */
  .video-hero { background: var(--bg-card); border: .5px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; margin-bottom: 20px; display: none; }
  .video-hero.visible { display: block; }
  .video-hero-top { background: var(--blue); padding: 16px 20px; display: flex; align-items: center; gap: 14px; }
  .hero-play { width: 44px; height: 44px; background: var(--orange); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .hero-tri { width: 0; height: 0; border-top: 8px solid transparent; border-bottom: 8px solid transparent; border-left: 15px solid white; margin-left: 4px; }
  .hero-info { flex: 1; }
  .hero-title { font-size: 14px; font-weight: 600; color: #fff; line-height: 1.4; }
  .hero-meta { font-size: 11px; color: rgba(255,255,255,0.55); margin-top: 3px; }
  .hero-btn { display: inline-flex; align-items: center; gap: 6px; background: var(--orange); color: #fff; font-size: 12px; font-weight: 600; padding: 9px 16px; border-radius: var(--radius-md); text-decoration: none; transition: background .12s; flex-shrink: 0; }
  .hero-btn:hover { background: var(--orange-dark); }

  /* lista */
  .section-title { font-size: 14px; font-weight: 600; color: var(--blue); margin-bottom: 12px; }
  .video-list { display: flex; flex-direction: column; gap: 8px; }

  .video-card {
    background: var(--bg-card); border: .5px solid var(--border); border-radius: var(--radius-md);
    padding: 12px 16px; display: flex; align-items: center; gap: 12px;
    cursor: pointer; text-decoration: none;
    transition: border-color .12s, box-shadow .12s;
  }
  .video-card:hover, .video-card.selected { border-color: var(--orange); box-shadow: 0 2px 8px rgba(244,121,32,0.12); }
  .video-card.selected { background: var(--orange-light); }

  .vc-num { width: 28px; height: 28px; border-radius: 50%; background: var(--bg); border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; color: var(--text-muted); flex-shrink: 0; transition: background .12s, color .12s, border-color .12s; }
  .video-card:hover .vc-num, .video-card.selected .vc-num { background: var(--orange); border-color: var(--orange); color: #fff; }
  .vc-name { font-size: 13px; color: var(--text-primary); line-height: 1.4; flex: 1; }
  .vc-arrow { font-size: 16px; color: var(--orange); opacity: 0; transition: opacity .12s; }
  .video-card:hover .vc-arrow, .video-card.selected .vc-arrow { opacity: 1; }

  /* vacío */
  .empty-state { text-align: center; padding: 56px 24px; color: var(--text-muted); font-size: 13px; line-height: 1.7; background: var(--bg-card); border: 1px dashed var(--border); border-radius: var(--radius-lg); }
  .empty-icon { font-size: 32px; margin-bottom: 12px; }
</style>
</head>
<body>
<div class="portal">

  <div class="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-logo-row">
        <img class="sidebar-logo-img" src="logo.png" alt="INFRA"
          onerror="this.style.display='none';document.getElementById('infra-txt').style.display='block'"/>
        <span id="infra-txt" style="display:none;font-size:20px;font-weight:700;color:#F47920;letter-spacing:.05em;">INFRA</span>
      </div>
      <div class="sidebar-subtitle">Material de apoyo</div>
      <div class="sidebar-title">Tutoriales SAP</div>
    </div>
    <div class="sidebar-list" id="sidebarList"></div>
  </div>

  <div class="main">
    <div class="main-topbar">
      <span class="topbar-crumb">Inicio</span>
      <span class="topbar-sep">›</span>
      <span class="topbar-crumb">Material de apoyo SAP</span>
      <span class="topbar-sep">›</span>
      <span class="topbar-current" id="topbarCurrent"></span>
    </div>
    <div class="main-header">
      <div class="main-title" id="mainTitle"></div>
      <div class="main-subtitle" id="mainSubtitle"></div>
    </div>
    <div class="main-body">
      <div class="objective-box">
        <div class="obj-icon">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="8" r="6" stroke="#F47920" stroke-width="1.5"/>
            <path d="M5 8l2 2 4-4" stroke="#F47920" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <div class="obj-label">Objetivo</div>
          <div class="obj-text" id="objText"></div>
        </div>
      </div>

      <div class="video-hero" id="videoHero">
        <div class="video-hero-top">
          <div class="hero-play"><div class="hero-tri"></div></div>
          <div class="hero-info">
            <div class="hero-title" id="heroTitle"></div>
            <div class="hero-meta" id="heroMeta"></div>
          </div>
          <a class="hero-btn" id="heroBtn" href="#" target="_blank" rel="noopener">▶ Ver video</a>
        </div>
      </div>

      <div id="videosSectionTitle" class="section-title"></div>
      <div class="video-list" id="videoList"></div>
    </div>
  </div>
</div>

<script>
/* =====================================================
   ✏️  CONFIGURACIÓN DE MÓDULOS Y VIDEOS
   Para agregar videos:
   { name: "Nombre del video", url: "https://empresa.sharepoint.com/..." }
   ===================================================== */
const modules = [
  {
    num:"01", label:"Carga masiva de clientes",
    obj:"Aprenderás a ejecutar la carga masiva de clientes en SAP, incluyendo visualización de interlocutores, RFC, CURP y condiciones de pago.",
    videos:[
      {name:"Visualiza clientes y sus interlocutores en SAP", url:"PEGA_AQUI_EL_LINK_DE_SHAREPOINT"},
      {name:"¿Qué es el interlocutor de un cliente y cómo encontrarlos en SAP?", url:"PEGA_AQUI_EL_LINK_DE_SHAREPOINT"},
      {name:"Visualizar el RFC, el CURP o el NIF de un cliente en SAP", url:"PEGA_AQUI_EL_LINK_DE_SHAREPOINT"},
      {name:"¿Cómo conocer la condición de pago del cliente en SAP?", url:"PEGA_AQUI_EL_LINK_DE_SHAREPOINT"}
    ]
  },
  {num:"02",label:"Gestión de precios",obj:"Comprenderás cómo gestionar y consultar precios dentro del sistema SAP.",videos:[]},
  {num:"03",label:"Venta de mercancía con inventario",obj:"Procesarás ventas de mercancía con control de inventario en SAP.",videos:[]},
  {num:"04",label:"Venta con entrega en sucursal",obj:"Gestionarás ventas con entrega directa en sucursal usando SAP.",videos:[]},
  {num:"05",label:"Venta terceros POS",obj:"Realizarás ventas a terceros a través del punto de venta en SAP.",videos:[]},
  {num:"06",label:"Vta 3r SAP - Solped / Traspaso",obj:"Ejecutarás el proceso de venta a terceros con solicitud de pedido y traspaso en SAP.",videos:[]},
  {num:"07",label:"Vta 3r SAP - Solped / Compra Pro",obj:"Gestionarás ventas a terceros con solicitud de pedido y compra pro en SAP.",videos:[]},
  {num:"08",label:"Traspasos directos MM con CP",obj:"Realizarás traspasos directos en gestión de materiales con centro de producción.",videos:[]},
  {num:"09",label:"Facturación anticipada",obj:"Procesarás facturas anticipadas dentro del flujo de ventas en SAP.",videos:[]},
  {num:"10",label:"Venta exportación con inventario",obj:"Gestionarás ventas de exportación con control de inventario en SAP.",videos:[]},
  {num:"11",label:"Vta 3r Expo - Solped / Traslado",obj:"Ejecutarás ventas a terceros de exportación con solicitud de pedido y traslado.",videos:[]},
  {num:"12",label:"Vta 3r Expo - Solped / Compras",obj:"Gestionarás ventas a terceros de exportación con solicitud de pedido y compras.",videos:[]},
  {num:"13",label:"Pedidos muestra",obj:"Crearás y gestionarás pedidos de muestra en SAP correctamente.",videos:[]},
  {num:"14",label:"Existencia ficticia",obj:"Comprenderás y trabajarás con existencias ficticias en el sistema SAP.",videos:[]},
  {num:"15",label:"Devoluciones INV con referencia",obj:"Procesarás devoluciones de inventario con referencia a documento original.",videos:[]},
  {num:"16",label:"Devolución sin referencia",obj:"Gestionarás devoluciones sin referencia a documento en SAP.",videos:[]},
  {num:"17",label:"NC por bonificación",obj:"Emitirás notas de crédito por bonificación dentro del sistema SAP.",videos:[]},
  {num:"18",label:"Venta con anticipos",obj:"Procesarás ventas que incluyen anticipos o pagos adelantados en SAP.",videos:[]},
  {num:"19",label:"Cancelaciones",obj:"Ejecutarás cancelaciones de documentos de venta en SAP de forma correcta.",videos:[]},
  {num:"20",label:"Refacturación",obj:"Realizarás el proceso de refacturación de documentos en SAP.",videos:[]},
  {num:"21",label:"Rebates",obj:"Configurarás y gestionarás acuerdos de rebates con clientes en SAP.",videos:[]},
  {num:"22",label:"Intercompany",obj:"Gestionarás transacciones intercompany entre sociedades en SAP.",videos:[]},
  {num:"23",label:"Catálogos",obj:"Administrarás y utilizarás catálogos de materiales en SAP.",videos:[]},
  {num:"24",label:"Reg. Info cliente / material",obj:"Registrarás y consultarás información de clientes y materiales en SAP.",videos:[]}
];

const sidebarList        = document.getElementById('sidebarList');
const mainTitle          = document.getElementById('mainTitle');
const mainSubtitle       = document.getElementById('mainSubtitle');
const topbarCurrent      = document.getElementById('topbarCurrent');
const objText            = document.getElementById('objText');
const videosSectionTitle = document.getElementById('videosSectionTitle');
const videoList          = document.getElementById('videoList');
const videoHero          = document.getElementById('videoHero');
const heroTitle          = document.getElementById('heroTitle');
const heroMeta           = document.getElementById('heroMeta');
const heroBtn            = document.getElementById('heroBtn');

let activeModIdx = 0;
let activeVidIdx = -1;

function renderMain(mod, vidIdx = -1) {
  mainTitle.textContent     = mod.label;
  topbarCurrent.textContent = mod.label;
  objText.textContent       = mod.obj;
  const count = mod.videos.length;
  mainSubtitle.textContent  = count > 0 ? `${count} video${count>1?'s':''} disponible${count>1?'s':''}` : 'Videos próximamente';

  if (vidIdx >= 0 && mod.videos[vidIdx]) {
    const v = mod.videos[vidIdx];
    heroTitle.textContent = v.name;
    heroMeta.textContent  = `Video ${vidIdx+1} de ${count} · SharePoint`;
    heroBtn.href          = v.url;
    videoHero.classList.add('visible');
  } else {
    videoHero.classList.remove('visible');
  }

  if (count > 0) {
    videosSectionTitle.textContent = 'Videos del módulo';
    videoList.innerHTML = mod.videos.map((v,i) => `
      <a class="video-card${i===vidIdx?' selected':''}" data-vidx="${i}" href="${v.url}" target="_blank" rel="noopener">
        <div class="vc-num">${i+1}</div>
        <div class="vc-name">${v.name}</div>
        <div class="vc-arrow">›</div>
      </a>`).join('');

    videoList.querySelectorAll('.video-card').forEach(card => {
      card.addEventListener('click', e => {
        const idx = parseInt(card.dataset.vidx);
        if (activeVidIdx !== idx) {
          e.preventDefault();
          activeVidIdx = idx;
          renderMain(modules[activeModIdx], activeVidIdx);
          syncSidebarVideos();
        }
      });
    });
  } else {
    videosSectionTitle.textContent = '';
    videoList.innerHTML = `<div class="empty-state"><div class="empty-icon">🎬</div>Los videos de este módulo estarán disponibles próximamente.</div>`;
  }
}

function syncSidebarVideos() {
  document.querySelectorAll('.sidebar-video-item').forEach(el => {
    el.classList.toggle('active-video',
      parseInt(el.dataset.modidx) === activeModIdx &&
      parseInt(el.dataset.vidx)  === activeVidIdx);
  });
}

modules.forEach((mod, mi) => {
  const block  = document.createElement('div');
  block.className = 'module-block';

  const header = document.createElement('div');
  header.className = 'module-header' + (mi===0 ? ' active' : '');
  header.innerHTML = `
    <span class="mod-num">${mod.num}</span>
    <span class="mod-label">${mod.label}</span>
    ${mod.videos.length > 0 ? `<span class="mod-badge">${mod.videos.length}</span>` : ''}
    <span class="mod-arrow">▶</span>`;

  const subList = document.createElement('div');
  subList.className = 'module-videos' + (mi===0 ? ' open' : '');

  if (mod.videos.length > 0) {
    mod.videos.forEach((v, vi) => {
      const item = document.createElement('div');
      item.className = 'sidebar-video-item';
      item.dataset.modidx = mi;
      item.dataset.vidx   = vi;
      item.innerHTML = `<span class="sv-dot"></span><span class="sv-label">${v.name}</span>`;
      item.addEventListener('click', () => {
        selectModule(mi);
        activeVidIdx = vi;
        renderMain(modules[mi], vi);
        syncSidebarVideos();
      });
      subList.appendChild(item);
    });
  } else {
    subList.innerHTML = `<div class="sidebar-empty">Sin videos aún</div>`;
  }

  header.addEventListener('click', () => selectModule(mi));
  block.appendChild(header);
  block.appendChild(subList);
  sidebarList.appendChild(block);
});

function selectModule(mi) {
  document.querySelectorAll('.module-header').forEach(h => h.classList.remove('active'));
  document.querySelectorAll('.module-videos').forEach(v => v.classList.remove('open'));
  const headers  = document.querySelectorAll('.module-header');
  const subLists = document.querySelectorAll('.module-videos');
  headers[mi].classList.add('active');
  subLists[mi].classList.add('open');
  activeModIdx = mi;
  activeVidIdx = -1;
  renderMain(modules[mi]);
  syncSidebarVideos();
  headers[mi].scrollIntoView({ block:'nearest', behavior:'smooth' });
}

renderMain(modules[0]);
</script>
</body>
</html>
